<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.aiorch.daily.plist — runs a full Asana sync every day at 8am
  Installed to: ~/Library/LaunchAgents/com.aiorch.daily.plist
  Generated by install.sh
-->
<plist version="1.0">
<dict>

  <key>Label</key>
  <string>com.aiorch.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>ORCH_HOME_PLACEHOLDER/bin/asana-sync</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>ORCH_HOME_PLACEHOLDER/logs/asana-sync.log</string>

  <key>StandardErrorPath</key>
  <string>ORCH_HOME_PLACEHOLDER/logs/asana-sync-error.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>ORCH_HOME</key>
    <string>ORCH_HOME_PLACEHOLDER</string>
    <key>HOME</key>
    <string>HOME_PLACEHOLDER</string>
    <key>PATH</key>
    <string>HOME_PLACEHOLDER/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

</dict>
</plist>
